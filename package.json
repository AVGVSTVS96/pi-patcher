{
  "name": "pi-patcher",
  "version": "0.1.0",
  "description": "Update-resilient self-healing patches for pi installs.",
  "type": "module",
  "bin": {
    "pi-patcher": "./dist/cli.js"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit && bun build src/cli.ts --target=node --outfile=dist/cli.js && chmod +x dist/cli.js",
    "prepack": "bun run build",
    "postinstall": "node ./dist/cli.js reconcile || true"
  },
  "files": [
    "dist",
    "prompts",
    "patches",
    "README.md"
  ],
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  },
  "license": "MIT"
}
